{
  "name": "pipilot-ide",
  "version": "0.1.0",
  "description": "AI-native code editor with integrated terminal, cloud management, and autonomous coding agent",
  "author": {
    "name": "Hans Ade",
    "email": "hans@pipilot.dev"
  },
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite --config vite.config.ts --host 0.0.0.0\" \"tsx server/index.ts\" \"tsx server/cloud.ts --standalone\"",
    "dev:client": "vite --config vite.config.ts --host 0.0.0.0",
    "dev:server": "tsx server/index.ts",
    "dev:cloud": "tsx server/cloud.ts --standalone",
    "build": "vite build --config vite.config.ts",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "electron:dev": "ELECTRON=1 vite dev",
    "electron:build": "ELECTRON=1 tsc && ELECTRON=1 vite build && electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
