{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/config.schema.json",
  "productName": "PiPilot IDE",
  "version": "0.1.0",
  "identifier": "dev.pipilot.ide",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:51730",
    "beforeDevCommand": "pnpm dev:client",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "PiPilot IDE",
        "width": 1440,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://js.puter.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net; connect-src 'self' http://localhost:51731 http://localhost:51732 https://* http://*; img-src 'self' data: blob: https://*; media-src 'self' blob:; worker-src 'self' blob:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/node-sidecar"
    ],
    "resources": [
      "resources/server-bundle.mjs",
      "resources/cloud-bundle.mjs",
      "resources/node_modules/**/*"
    ],
    "publisher": "PiPilot",
    "copyright": "2025 PiPilot",
    "category": "DeveloperTool",
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://github.com/pipilot-dev/pipilot-ide/releases/latest/download/latest.json"
      ]
    }
  }
}
