{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "PiPilot IDE",
  "version": "0.1.0",
  "identifier": "com.pipilot.ide",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:51730",
    "beforeDevCommand": "pnpm dev:client",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "title": "PiPilot IDE",
    "windows": [
      {
        "title": "PiPilot IDE",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": []
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": [
        {
          "name": "node-server",
          "cmd": "node",
          "args": true
        },
        {
          "name": "tsx-server",
          "cmd": "npx",
          "args": true
        }
      ]
    }
  }
}
