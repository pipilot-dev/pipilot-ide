{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PiPilot IDE",
  "version": "0.1.0",
  "identifier": "dev.pipilot.ide",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:51730",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "PiPilot IDE",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "PiPilot",
    "copyright": "© 2024 PiPilot",
    "category": "DeveloperTool"
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY5RjUxRDEzMjQzMzJCNDgKUldSSUt6TWtFeDMxYVdpQzFjUkFsY3JSa1ZmV2JtczV2N1RWSlVpTkJMd0Jlc3hmLzlLL25mdkgK",
      "endpoints": [
        "https://github.com/pipilot-dev/pipilot-ide/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "windows": {
        "installerArgs": []
      }
    }
  }
}
